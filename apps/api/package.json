{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "start": "bun run dist/index.js",
    "lint": "tsc --noEmit",
    "test": "bun run scripts/migrate-test-db.ts run",
    "test:watch": "bun run scripts/migrate-test-db.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@prisma/client": "^5.10.0",
    "@votesphere/types": "workspace:*",
    "@votesphere/zod-schemas": "workspace:*",
    "arctic": "^3.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "hono": "^4.0.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^5.10.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "bun run prisma/seed.ts"
  }
}
