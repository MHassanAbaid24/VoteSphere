# Database Connection String (PostgreSQL with Prisma)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/votesphere?schema=public"

# Node Environment
NODE_ENV="development"

# Secret Key used for JWT verification and token signing
JWT_SECRET="supersecret-default-jwt-secret-key-for-development"

# Allowed CORS origins (comma-separated if multiple)
ALLOWED_ORIGINS="http://localhost:8080,http://localhost:5173"

# Port where the backend listens
PORT=3000

# Gmail configuration for sending emails
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Frontend application URL (used in email links)
APP_URL="http://localhost:8080"
